{
  "name": "@llmcost/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for calculating LLM API costs",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:e2e": "vitest run tests/e2e"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "jsonpath-plus": "^10.3.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
