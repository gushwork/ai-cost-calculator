{
  "name": "ai-cost-calculator",
  "version": "0.2.3",
  "description": "TypeScript SDK for calculating LLM API costs",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prepare-config": "cp ../configs/*.json src/data/",
    "build": "npm run prepare-config && tsc -p tsconfig.build.json && cp ../configs/*.json dist/data/",
    "typecheck": "npm run prepare-config && tsc --noEmit -p tsconfig.json",
    "test": "bun test",
    "test:e2e": "bun test tests/e2e"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/gushwork/ai-cost-calculator",
    "directory": "node"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "jsonpath-plus": "^10.4.0"
  },
  "devDependencies": {
    "bun-types": "latest",
    "typescript": "^5.9.3"
  }
}
